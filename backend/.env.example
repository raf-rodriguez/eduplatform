# ============================================
# EduPlatform - Variables de Entorno
# ============================================

# Entorno
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# ============================================
# Base de Datos
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/eduplatform?schema=public"

# Redis (Cache y Sesiones)
REDIS_URL=redis://localhost:6379

# ============================================
# Autenticación
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# OpenAI / Agentes IA
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000

# Fallback LLM (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ============================================
# Stripe (Pagos)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_STUDENT=price_student_plan_id
STRIPE_PRICE_FAMILY=price_family_plan_id
STRIPE_PRICE_PREMIUM=price_premium_plan_id

# ============================================
# Almacenamiento (AWS S3 o MinIO)
# ============================================
# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=eduplatform-uploads

# O MinIO (local)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eduplatform

# ============================================
# Email (SendGrid o SMTP)
# ============================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@eduplatform.com
EMAIL_FROM_NAME=EduPlatform

# SMTP alternativo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# Configuración de Agentes
# ============================================
AGENT_MAX_CONCURRENT_TASKS=10
AGENT_TASK_TIMEOUT_MS=30000
AGENT_QUEUE_MAX_SIZE=1000
AGENT_RETRY_ATTEMPTS=3
AGENT_RATE_LIMIT_PER_MINUTE=60

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# Seguridad
# ============================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
